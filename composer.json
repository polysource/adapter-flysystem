{
    "name": "polysource/adapter-flysystem",
    "description": "Polysource — Flysystem adapter: list, browse, upload, delete files on S3 / local / FTP / Azure / GCS through the admin.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "polysource",
        "flysystem",
        "files",
        "s3",
        "adapter",
        "symfony"
    ],
    "homepage": "https://github.com/polysource/polysource",
    "support": {
        "issues": "https://github.com/polysource/polysource/issues",
        "source": "https://github.com/polysource/polysource"
    },
    "require": {
        "php": ">=8.1",
        "league/flysystem": "^3.0",
        "polysource/core": "^0.1",
        "symfony/config": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^5.4 || ^6.0 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "async-aws/simple-s3": "^1.0 || ^2.0",
        "league/flysystem-async-aws-s3": "^3.29",
        "league/flysystem-memory": "^3.0",
        "phpunit/phpunit": "^10.5 || ^11.5",
        "polysource/symfony-bundle": "0.1.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Polysource\\Adapter\\Flysystem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Polysource\\Adapter\\Flysystem\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
